body {
    font: @baseFont;
}

p {
    white-space: pre-wrap;
}

.action {
    color: @action;
    font-style: italic;
    font-weight: bold;
}

.typing {
    color: #4C566A;
}

.quote {
    color: #A3BE8C;
}

.alert {
    margin-left: 0px;
    margin-right: 0px;
    background-color: @orange;
}

.alert_name {
    background-color: @orange;
    font: @bigBold;
}

a {
    color: @link;
    font-weight: bold
}
