QPushButton
{
    background-color: #A3BE8C;
    background-image: url("@getImagePath(emoteButton/emoteButton.svg)");
    background-repeat: none;
    background-position: center;
    border-top-right-radius: 5px;
    border: none;
    width: 24px;
    height: 24px;
}

QPushButton:hover
{
    background-color: #A3BE8C;
}

QPushButton:pressed
{
    background-color: #A3BE8C;
}

QPushButton:focus
{
    outline: none;
}
